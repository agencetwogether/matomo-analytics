{
    "name": "agencetwogether/matomo-analytics",
    "description": "Matomo Analytics integration for Filament Panels with a set of widgets to display your analytics data in a beautiful way.",
    "keywords": [
        "agencetwogether",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "matomo",
        "analytics",
        "dashboard"
    ],
    "homepage": "https://github.com/agencetwogether/matomo-analytics",
    "support": {
        "issues": "https://github.com/agencetwogether/matomo-analytics/issues",
        "source": "https://github.com/agencetwogether/matomo-analytics"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Agence Twogether",
            "email": "github@agencetwogether.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Agencetwogether\\MatomoAnalytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agencetwogether\\MatomoAnalytics\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agencetwogether\\MatomoAnalytics\\MatomoAnalyticsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
